{
  "name": "content-first-blog-spikes",
  "private": true,
  "type": "module",
  "scripts": {
    "spike:build-ir": "npx shadow-cljs compile spike",
    "spike:run-ir": "node .shadow-cljs/builds/spike/release/cli.cjs",
    "spike:prepare-site": "npm run spike:build-ir && npm run spike:run-ir",
    "spike:build-site": "npm run spike:prepare-site && astro build --root spikes/astro-adapter/site"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "astro": "6.1.8",
    "mermaid": "^11.12.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "shadow-cljs": "3.4.4"
  }
}
