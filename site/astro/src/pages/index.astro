---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialIcon from "../components/SocialIcon.astro";
import posts from "../data/posts.json";
import runtime from "../../managed/runtime-config.json";

const publishedAt = (post) => post.published_at ?? post.created_at ?? "";
const sortedPosts = [...posts].sort((left, right) =>
  publishedAt(right).localeCompare(publishedAt(left))
);
const postsByYear = Object.entries(
  sortedPosts.reduce((groups, post) => {
    const year = publishedAt(post).slice(0, 4) || "Undated";
    groups[year] ??= [];
    groups[year].push(post);
    return groups;
  }, {})
);
const tagCounts = Object.entries(
  sortedPosts.reduce((counts, post) => {
    for (const tag of post.tags) {
      counts[tag] = (counts[tag] ?? 0) + 1;
    }
    return counts;
  }, {})
).sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0]));
const hero = runtime.site.hero;
---

<BaseLayout
  title={runtime.site.title}
  description={runtime.site.description}
>
  <main class="home-layout">
    <section class="home-hero panel stack-lg">
      <p class="meta-eyebrow">{hero.eyebrow}</p>
      <h1>{hero.headline}</h1>
      <p class="hero-copy">{hero.copy}</p>
      <ul class="hero-links cluster" aria-label="Social links">
        {hero.links.map((link) => (
          <li>
            <a href={link.href} aria-label={link.label} title={link.label}>
              <SocialIcon label={link.label} />
            </a>
          </li>
        ))}
      </ul>
      <dl class="hero-stats">
        <div>
          <dt>Posts</dt>
          <dd>{sortedPosts.length}</dd>
        </div>
        <div>
          <dt>Years</dt>
          <dd>{postsByYear.length}</dd>
        </div>
        <div>
          <dt>Tags</dt>
          <dd>{tagCounts.length}</dd>
        </div>
      </dl>
    </section>

    <section class="home-panel home-panel--primary panel">
      <div class="section-heading stack-sm">
        <h2>Latest writing</h2>
        <p>Recent posts, working notes, and essays in reverse chronological order.</p>
      </div>
      <ul class="post-list">
        {sortedPosts.map((post) => (
          <li class="post-card stack-md">
            <div class="post-card-meta">
              <span>{publishedAt(post)}</span>
            </div>
            <h3><a href={post.url}>{post.title}</a></h3>
            <p class="post-summary">{post.summary}</p>
            <ul class="post-taxonomy cluster">
              {post.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </section>

    <aside class="home-sidebar">
      <section class="home-panel home-panel--archive panel">
        <div class="section-heading stack-sm">
          <h2>Archive</h2>
          <p>Browse writing over time by year.</p>
        </div>
        <div class="archive-groups">
          {postsByYear.map(([year, yearPosts]) => (
            <section class="archive-group stack-sm">
              <h3>{year}</h3>
              <ul>
                {yearPosts.map((post) => (
                  <li>
                    <a href={post.url}>{post.title}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>

      <section class="home-panel home-panel--taxonomy panel">
        <div class="section-heading stack-sm">
          <h2>Tags</h2>
          <p>Browse recurring topics without adding maintenance overhead to writing.</p>
        </div>
        <ul class="tag-cloud cluster">
          {tagCounts.map(([tag, count]) => (
            <li>
              <span>{tag}</span>
              <strong>{count}</strong>
            </li>
          ))}
        </ul>
      </section>
    </aside>
  </main>
</BaseLayout>
