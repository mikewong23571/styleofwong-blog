---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const publishedAt = frontmatter.published_at ?? frontmatter.created_at;
---

<BaseLayout title={frontmatter.title} description={frontmatter.summary}>
  <main class="post-shell panel">
    <div class="post-nav">
      <a class="home-link" href="/">Back to index</a>
    </div>
    <article class="post prose">
      <header class="post-header stack-md">
        {publishedAt && <p class="meta-eyebrow">Published {publishedAt}</p>}
        <h1>{frontmatter.title}</h1>
        {frontmatter.summary && <p class="post-summary">{frontmatter.summary}</p>}
        {frontmatter.tags?.length > 0 && (
          <ul class="post-taxonomy cluster">
            {frontmatter.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )}
      </header>
      <slot />
    </article>
  </main>
</BaseLayout>
